    "file": "Mainstream_Lean.html",
    "tag": "td",
    "text": "gcongr does not require you to state which hypotheses you are substituting",
    "html": "<td><p><code class=\"docutils literal notranslate\"><span class=\"pre\">gcongr</span></code> does not require you to state which hypotheses you are</p>\n<p>substituting</p>\n</td>",
