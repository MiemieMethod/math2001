[
  {
    "id": "index:0001",
    "file": "index.html",
    "tag": "h1",
    "text": "The Mechanics of Proof",
    "html": "<h1>The Mechanics of Proof<a class=\"headerlink\" href=\"#the-mechanics-of-proof\" title=\"Permalink to this headline\"></a></h1>",
    "zh": ""
  },
  {
    "id": "index:0002",
    "file": "index.html",
    "tag": "p",
    "text": "This is a book dealing with how to write careful, rigorous mathematical proofs. The book is paired with code in the computer formalization language Lean . Head over to the associated GitHub repository, https://github.com/hrmacbeth/math2001 , to download this code to your own computer or to open it in the cloud on Gitpod.",
    "html": "<p>This is a book dealing with how to write careful, rigorous mathematical proofs.\nThe book is paired with code in the computer formalization language\n<a class=\"reference external\" href=\"https://leanprover.github.io/about/\">Lean</a>. Head over to the associated GitHub repository,\n<a class=\"reference external\" href=\"https://github.com/hrmacbeth/math2001\">https://github.com/hrmacbeth/math2001</a>, to download this code to your own computer or to open it in\nthe cloud on Gitpod.</p>",
    "zh": ""
  },
  {
    "id": "index:0003",
    "file": "index.html",
    "tag": "p",
    "text": "This book is aimed at the early university level and has been written for the course Math 2001, at Fordham University. Please reach out to the author, Heather Macbeth , with comments and corrections.",
    "html": "<p>This book is aimed at the early university level and has been written for the course\nMath 2001, at Fordham University.  Please reach out to the author,\n<a class=\"reference external\" href=\"https://faculty.fordham.edu/hmacbeth1/\">Heather Macbeth</a>, with comments and corrections.</p>",
    "zh": ""
  },
